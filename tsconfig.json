{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["es2022"],
        "jsx": "react-jsx",
        "types": ["node"],
        "strict": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["src", "tests", "golden"]
}
