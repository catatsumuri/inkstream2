{
    "name": "@catatsumuri/inkstream",
    "version": "0.0.0",
    "description": "Markdown engine for Mintlify-style JSX tags, Zenn directives, and GFM: AST-based tag pairing instead of line-based string preprocessing.",
    "license": "MIT",
    "author": "catatsumuri",
    "private": true,
    "type": "module",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "dist"
    ],
    "bin": {
        "inkstream": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        },
        "./react/mermaid": {
            "types": "./dist/react/mermaid-diagram.d.ts",
            "import": "./dist/react/mermaid-diagram.js"
        },
        "./styles.css": "./dist/react/styles.css"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node scripts/finish-build.mjs",
        "prepare": "npm run build",
        "test": "node --import tsx --test tests/*.test.ts",
        "typecheck": "tsc --noEmit",
        "golden": "tsx golden/diff.ts"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@types/mdast": "^4.0.4",
        "@types/unist": "^3.0.3",
        "hast-util-to-html": "^9.0.5",
        "remark-directive": "^4.0.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "unified": "^11.0.5",
        "vfile": "^6.0.3"
    },
    "peerDependencies": {
        "lucide-react": ">=0.400.0 <1.0.0",
        "mermaid": "^11.0.0",
        "react": "^18.0.0 || ^19.0.0",
        "react-markdown": "^10.0.0",
        "recharts": "^3.0.0",
        "shiki": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "lucide-react": {
            "optional": true
        },
        "mermaid": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "react-markdown": {
            "optional": true
        },
        "recharts": {
            "optional": true
        },
        "shiki": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/jsdom": "^28.0.3",
        "@types/node": "^20.19.43",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.3",
        "jsdom": "^29.1.1",
        "lucide-react": "^0.475.0",
        "mdast-util-to-hast": "^13.2.0",
        "mermaid": "^11.12.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-markdown": "^10.1.0",
        "recharts": "^3.8.1",
        "shiki": "^4.3.1",
        "tsx": "^4.23.0",
        "typescript": "^5.9.3"
    }
}
